      "cell_type": "code",
      "source": "my_list = [1, 2, 3, 2, 4, 5, 1]\n\nduplicates = []\n\nfor item in my_list:\n    if my_list.count(item) > 1 and item not in duplicates:\n        duplicates.append(item)\n\nprint(\"Duplicate values:\", duplicates)",

    {
      "id": "bdbd140d-c816-4954-b27c-320640d2ed98",
      "cell_type": "code",
      "source": "data = {\n    \"a\": 10,\n    \"b\": 20,\n    \"c\": \"Hello\",\n    \"d\": 5\n}\n\ntotal = 0\n\nfor value in data.values():\n    if isinstance(value, (int, float)):\n        total += value\n\nprint(\"Sum of numeric values =\", total)",
      "metadata": {
        "trusted": true
      },
      "outputs": [
        {
          "name": "stdout",
          "output_type": "stream",
          "text": "Sum of numeric values = 35\n"
        }
      ],
      "execution_count": 7
    },

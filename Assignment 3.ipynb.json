    {
      "id": "6ef689e2-4400-4f58-97de-8cf1a2ceae4c",
      "cell_type": "code",
      "source": "my_list = [10, \"Ali\", 5.5, \"Python\"]\n\nfound = False\n\nfor item in my_list:\n    if isinstance(item, (int, float)):\n        found = True\n        break\n\nif found:\n    print(\"Numeric value exists in list\")\nelse:\n    print(\"No numeric value found\")",
      "metadata": {
        "trusted": true
      },
      "outputs": [
        {
          "name": "stdout",
          "output_type": "stream",
          "text": "Numeric value exists in list\n"

      "source": "# Calculator Program\n\na = float(input(\"Enter first number: \"))\nb = float(input(\"Enter second number: \"))\n\nprint(\"Addition =\", a + b)\nprint(\"Subtraction =\", a - b)\nprint(\"Multiplication =\", a * b)\n\nif b != 0:\n    print(\"Division =\", a / b)\nelse:\n    print(\"Division not possible\")\n\nprint(\"Power =\", a ** b)",
